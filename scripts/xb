#!/usr/bin/env bash
set -euo pipefail

is_xenobot_root() {
  local dir="$1"
  [[ -f "$dir/Cargo.toml" ]] || return 1
  [[ -f "$dir/crates/cli/Cargo.toml" ]] || return 1
  grep -q 'name = "xenobot-cli"' "$dir/crates/cli/Cargo.toml"
}

find_xenobot_root() {
  local dir="${PWD}"
  while [[ "$dir" != "/" ]]; do
    if is_xenobot_root "$dir"; then
      printf "%s\n" "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  if [[ -n "${XENOBOT_ROOT:-}" ]] && is_xenobot_root "$XENOBOT_ROOT"; then
    printf "%s\n" "$XENOBOT_ROOT"
    return 0
  fi

  local candidates=(
    "$HOME/Desktop/open-resources-programs/My-program/Xenobot"
    "$HOME/Desktop/open-resources-programs/GitHub/Myself/Xenobot"
  )
  local candidate
  for candidate in "${candidates[@]}"; do
    if is_xenobot_root "$candidate"; then
      printf "%s\n" "$candidate"
      return 0
    fi
  done

  local discovered
  discovered="$(find "$HOME" -maxdepth 6 -type f -name Cargo.toml -path "*/Xenobot/Cargo.toml" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$discovered" ]]; then
    candidate="$(dirname "$discovered")"
    if is_xenobot_root "$candidate"; then
      printf "%s\n" "$candidate"
      return 0
    fi
  fi

  return 1
}

usage() {
  cat <<'EOF'
Usage:
  xb root
  xb cargo <args...>
  xb mcp start [--host <host>] [--port <port>] [--db-path <path>] [--no-sse] [--no-streamable-http]
  xb mcp smoke [--url <base-url>] [--timeout-ms <ms>]
  xb mcp preset [--url <base-url>] --target <claude-desktop|chatwise|opencode> [--format <text|json|yaml|csv|table>]
  xb api sandbox-doctor [--file-gateway-dir <path>] [--format <text|json|yaml|csv|table>]
  xb api sandbox-up [--db-path <path>] [--file-gateway-dir <path>] [--file-gateway-poll-ms <ms>] [--file-gateway-response-ttl-seconds <seconds>]
  xb api sandbox-health [--file-gateway-dir <path>] [--timeout-ms <ms>] [--format <text|json|yaml|csv|table>]
  xb web doctor [--fix-dns] [--dns1 <ip>] [--dns2 <ip>] [--service <name>]...
  xb web bootstrap [--strict] [--with-typecheck] [--extreme] [--offline-bundle <path>]
  xb web bundle create [--output <path>]
  xb web bundle restore [--input <path>]
  xb web bundle info [--input <path>]
  xb web deps-update [--refresh-lockfile] [--skip-typecheck] [--bundle-output <path>]
  xb <xenobot-cli args...>

Examples:
  xb api status
  xb api start --db-path /tmp/xenobot.db
  xb api sandbox-doctor
  xb api sandbox-up --db-path /tmp/xenobot.db
  xb api sandbox-health
  xb mcp start --db-path /tmp/xenobot.db
  xb mcp smoke --url http://127.0.0.1:8081
  xb mcp preset --url http://127.0.0.1:8081 --target claude-desktop --format json
  xb web doctor --fix-dns
  xb web bundle create
  xb web bootstrap --extreme --offline-bundle .xenobot/offline/frontend-offline-bundle.tar.gz
  xb web deps-update --bundle-output .xenobot/offline/frontend-offline-bundle.tar.gz
  xb web bootstrap --with-typecheck
  xb cargo test -p xenobot-api -p xenobot-cli --features "api,analysis"
EOF
}

main() {
  local root
  if ! root="$(find_xenobot_root)"; then
    echo "error: Xenobot root not found. Set XENOBOT_ROOT or run inside the Xenobot tree." >&2
    exit 1
  fi

  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  case "$1" in
    root)
      printf "%s\n" "$root"
      ;;
    web)
      shift
      case "${1:-}" in
        doctor)
          shift || true
          local apply_fix_dns=0
          local dns1="223.5.5.5"
          local dns2="8.8.8.8"
          local declared_services=()
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --fix-dns)
                apply_fix_dns=1
                ;;
              --dns1)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --dns1" >&2
                  exit 2
                }
                dns1="$1"
                ;;
              --dns2)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --dns2" >&2
                  exit 2
                }
                dns2="$1"
                ;;
              --service)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --service" >&2
                  exit 2
                }
                declared_services+=("$1")
                ;;
              *)
                echo "error: unknown doctor option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done

          if [[ ${apply_fix_dns} -eq 1 ]]; then
            local target_services=()
            if [[ ${#declared_services[@]} -gt 0 ]]; then
              target_services=("${declared_services[@]}")
            else
              target_services+=("Wi-Fi")
              local first_ordered_service
              first_ordered_service="$(networksetup -listnetworkserviceorder 2>/dev/null | awk '/^\([0-9]+\)/ {sub(/^\([0-9]+\) /, ""); print; exit}')"
              if [[ -n "${first_ordered_service}" ]]; then
                local has_service=0
                local svc
                for svc in "${target_services[@]}"; do
                  if [[ "${svc}" == "${first_ordered_service}" ]]; then
                    has_service=1
                    break
                  fi
                done
                if [[ ${has_service} -eq 0 ]]; then
                  target_services+=("${first_ordered_service}")
                fi
              fi
            fi

            echo "[xb web doctor] applying DNS fix (explicit opt-in): ${dns1}, ${dns2}"
            local svc
            for svc in "${target_services[@]}"; do
              if networksetup -setdnsservers "${svc}" "${dns1}" "${dns2}" >/dev/null 2>&1; then
                echo "[xb web doctor] DNS updated for service: ${svc}"
              else
                echo "[xb web doctor] notice: failed to update DNS for service: ${svc}"
              fi
            done
          fi

          local frontend_dir="$root/crates/web/frontend"
          local bundle_path="$root/.xenobot/offline/frontend-offline-bundle.tar.gz"
          echo "[xb web doctor] xenobot root: $root"
          echo "[xb web doctor] frontend dir: $frontend_dir"
          echo "[xb web doctor] system: $(uname -s) $(uname -m)"
          if command -v node >/dev/null 2>&1; then
            echo "[xb web doctor] node: $(node --version)"
          else
            echo "[xb web doctor] node: not found"
          fi
          if command -v pnpm >/dev/null 2>&1; then
            echo "[xb web doctor] pnpm: $(pnpm --version)"
          else
            echo "[xb web doctor] pnpm: not found"
          fi
          if command -v xcode-select >/dev/null 2>&1; then
            if xcode-select -p >/dev/null 2>&1; then
              echo "[xb web doctor] xcode-clt: installed ($(xcode-select -p))"
            else
              echo "[xb web doctor] xcode-clt: missing (run: xcode-select --install)"
            fi
          else
            echo "[xb web doctor] xcode-select: not found"
          fi
          if [[ -f "$frontend_dir/.npmrc" ]]; then
            echo "[xb web doctor] .npmrc: $frontend_dir/.npmrc"
            sed 's/^/[xb web doctor]   /' "$frontend_dir/.npmrc"
          else
            echo "[xb web doctor] .npmrc: missing"
          fi
          if [[ -f "$frontend_dir/pnpm-lock.yaml" ]]; then
            echo "[xb web doctor] pnpm-lock.yaml: present"
          else
            echo "[xb web doctor] pnpm-lock.yaml: missing"
          fi
          if [[ -d "$frontend_dir/node_modules" ]]; then
            echo "[xb web doctor] node_modules: present"
          else
            echo "[xb web doctor] node_modules: missing"
          fi
          if [[ -f "$bundle_path" ]]; then
            echo "[xb web doctor] offline bundle: present ($bundle_path)"
          else
            echo "[xb web doctor] offline bundle: missing ($bundle_path)"
          fi
          if command -v curl >/dev/null 2>&1; then
            if curl -fsS --max-time 8 https://registry.npmjs.org/-/ping >/dev/null 2>&1; then
              echo "[xb web doctor] npm registry dns/network: OK"
            else
              echo "[xb web doctor] npm registry dns/network: FAIL (cannot resolve/reach https://registry.npmjs.org)"
            fi
          else
            echo "[xb web doctor] curl: not found"
          fi
          exit 0
          ;;
        bootstrap)
          shift || true
          exec "$root/scripts/frontend_bootstrap.sh" "$@"
          ;;
        bundle)
          shift || true
          case "${1:-}" in
            create|restore|info)
              local action="$1"
              shift || true
              exec "$root/scripts/frontend_offline_bundle.sh" "$action" "$@"
              ;;
            *)
              echo "error: unsupported xb web bundle subcommand. Use: xb web bundle create|restore|info [options]" >&2
              exit 2
              ;;
          esac
          ;;
        deps-update)
          shift || true
          exec "$root/scripts/frontend_deps_update.sh" "$@"
          ;;
        *)
          echo "error: unsupported xb web subcommand. Use: xb web doctor | xb web bootstrap ... | xb web bundle ..." >&2
          exit 2
          ;;
      esac
      ;;
    mcp)
      shift || true
      case "${1:-}" in
        start|up)
          shift || true
          local host="127.0.0.1"
          local port="8081"
          local db_path=""
          local no_sse=0
          local no_streamable_http=0
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --host)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --host" >&2
                  exit 2
                }
                host="$1"
                ;;
              --port)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --port" >&2
                  exit 2
                }
                port="$1"
                ;;
              --db-path)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --db-path" >&2
                  exit 2
                }
                db_path="$1"
                ;;
              --no-sse)
                no_sse=1
                ;;
              --no-streamable-http)
                no_streamable_http=1
                ;;
              *)
                echo "error: unknown mcp start option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done

          local args=(--host "$host" --port "$port")
          if [[ -n "$db_path" ]]; then
            args+=(--db-path "$db_path")
          fi
          if [[ $no_sse -eq 1 ]]; then
            args+=(--no-sse)
          fi
          if [[ $no_streamable_http -eq 1 ]]; then
            args+=(--no-streamable-http)
          fi
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-mcp -- "${args[@]}"
          ;;
        smoke)
          shift || true
          local url="http://127.0.0.1:8081"
          local timeout_ms="5000"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --url)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --url" >&2
                  exit 2
                }
                url="$1"
                ;;
              --timeout-ms)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --timeout-ms" >&2
                  exit 2
                }
                timeout_ms="$1"
                ;;
              *)
                echo "error: unknown mcp smoke option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- \
            api mcp-smoke --url "$url" --timeout-ms "$timeout_ms"
          ;;
        preset)
          shift || true
          local url="http://127.0.0.1:8081"
          local target=""
          local format="json"
          local timeout_ms="5000"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --url)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --url" >&2
                  exit 2
                }
                url="$1"
                ;;
              --target)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --target" >&2
                  exit 2
                }
                target="$1"
                ;;
              --format)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --format" >&2
                  exit 2
                }
                format="$1"
                ;;
              --timeout-ms)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --timeout-ms" >&2
                  exit 2
                }
                timeout_ms="$1"
                ;;
              *)
                echo "error: unknown mcp preset option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done
          if [[ -z "$target" ]]; then
            echo "error: --target is required for xb mcp preset" >&2
            exit 2
          fi
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- \
            api mcp-preset --url "$url" --target "$target" --format "$format" --timeout-ms "$timeout_ms"
          ;;
        "")
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-mcp -- --help
          ;;
        *)
          echo "error: unsupported xb mcp subcommand. Use: start|smoke|preset" >&2
          exit 2
          ;;
      esac
      ;;
    api)
      shift || true
      case "${1:-}" in
        sandbox-doctor)
          shift || true
          local tmp_base="${TMPDIR:-/tmp}"
          tmp_base="${tmp_base%/}"
          [[ -n "$tmp_base" ]] || tmp_base="/tmp"
          local gateway_dir="${tmp_base}/xenobot-file-api"
          local format="json"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --file-gateway-dir)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --file-gateway-dir" >&2
                  exit 2
                }
                gateway_dir="$1"
                ;;
              --format)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --format" >&2
                  exit 2
                }
                format="$1"
                ;;
              *)
                echo "error: unknown sandbox-doctor option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- \
            api sandbox-doctor --file-gateway-dir "$gateway_dir" --format "$format"
          ;;
        sandbox-up)
          shift || true
          local db_path="/tmp/xenobot.db"
          local tmp_base="${TMPDIR:-/tmp}"
          tmp_base="${tmp_base%/}"
          [[ -n "$tmp_base" ]] || tmp_base="/tmp"
          local gateway_dir="${tmp_base}/xenobot-file-api"
          local poll_ms="300"
          local ttl_seconds="120"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --db-path)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --db-path" >&2
                  exit 2
                }
                db_path="$1"
                ;;
              --file-gateway-dir)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --file-gateway-dir" >&2
                  exit 2
                }
                gateway_dir="$1"
                ;;
              --file-gateway-poll-ms)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --file-gateway-poll-ms" >&2
                  exit 2
                }
                poll_ms="$1"
                ;;
              --file-gateway-response-ttl-seconds)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --file-gateway-response-ttl-seconds" >&2
                  exit 2
                }
                ttl_seconds="$1"
                ;;
              *)
                echo "error: unknown sandbox-up option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- \
            api start \
            --force-file-gateway \
            --file-gateway-dir "$gateway_dir" \
            --file-gateway-poll-ms "$poll_ms" \
            --file-gateway-response-ttl-seconds "$ttl_seconds" \
            --db-path "$db_path"
          ;;
        sandbox-health)
          shift || true
          local tmp_base="${TMPDIR:-/tmp}"
          tmp_base="${tmp_base%/}"
          [[ -n "$tmp_base" ]] || tmp_base="/tmp"
          local gateway_dir="${tmp_base}/xenobot-file-api"
          local timeout_ms="5000"
          local format="json"
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --file-gateway-dir)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --file-gateway-dir" >&2
                  exit 2
                }
                gateway_dir="$1"
                ;;
              --timeout-ms)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --timeout-ms" >&2
                  exit 2
                }
                timeout_ms="$1"
                ;;
              --format)
                shift
                [[ $# -gt 0 ]] || {
                  echo "error: missing value for --format" >&2
                  exit 2
                }
                format="$1"
                ;;
              *)
                echo "error: unknown sandbox-health option '$1'" >&2
                exit 2
                ;;
            esac
            shift
          done
          if cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- \
            api gateway-call \
            --file-gateway-dir "$gateway_dir" \
            --method GET \
            --path /health \
            --timeout-ms "$timeout_ms" \
            --format "$format"; then
            exit 0
          fi
          echo "[xb api sandbox-health] gateway request failed. Start server first:" >&2
          echo "  xb api sandbox-up --file-gateway-dir \"$gateway_dir\" --db-path /tmp/xenobot.db" >&2
          exit 1
          ;;
        "")
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- api --help
          ;;
        *)
          exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- api "$@"
          ;;
      esac
      ;;
    cargo)
      shift
      exec cargo --manifest-path "$root/Cargo.toml" "$@"
      ;;
    *)
      exec cargo run --manifest-path "$root/Cargo.toml" -p xenobot-cli --features "api,analysis" -- "$@"
      ;;
  esac
}

main "$@"
